{
  "name": "odin-book-api",
  "version": "1.0.0",
  "description": "RESTful API for Odin Book website.",
  "main": "./dist/app.ts",
  "type": "module",
  "imports": {
    "#src/*": "./dist/*"
  },
  "scripts": {
    "test": "NODE_ENV=test vitest",
    "dev": "NODE_ENV=development tsx --watch ./src/app.ts",
    "build": "tsc",
    "start": "NODE_ENV=production node ./dist/app.js",
    "generate:openapi": "tsx ./src/lib/openapi/generate/generate-document.ts"
  },
  "author": "Abdulrahman Ali",
  "license": "MIT",
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "passport": "^0.7.0",
    "pg": "^8.21.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/eslint-plugin": "^1.6.18",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
