generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["typedSql"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  email    String @unique @db.VarChar(254)
  username String @db.VarChar(100)
  fullName String @db.VarChar(100)
  password String
}
